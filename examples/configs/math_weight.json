{
    "mode": "weight",
    "env_type": "math",
    "system_prompt": "You are a math competition solver. Solve step by step and present your final answer in \\boxed{} notation.",
    "llm_clients": {
        "task": {
            "model": "anthropic/claude-haiku-4-5-20251001",
            "api_base": ""
        }
    },
    "skyrl": {
        "base_model": "Qwen/Qwen2.5-0.5B-Instruct",
        "backend_type": "skyrl_train",
        "backend_config": {
            "strategy": "fsdp2",
            "trainer.placement.colocate_all": true,
            "trainer.placement.policy_num_gpus_per_node": 1,
            "trainer.placement.ref_num_gpus_per_node": 1,
            "generator.inference_engine.num_engines": 1,
            "generator.inference_engine.tensor_parallel_size": 1,
            "trainer.train_batch_size": 8,
            "trainer.policy_mini_batch_size": 4,
            "trainer.micro_forward_batch_size_per_gpu": 2,
            "trainer.micro_train_batch_size_per_gpu": 2,
            "trainer.max_prompt_length": 256,
            "generator.sampling_params.max_generate_length": 512,
            "generator.inference_engine.gpu_memory_utilization": 0.4,
            "trainer.use_sample_packing": false
        },
        "lora_config": {
            "rank": 8,
            "alpha": 16.0
        },
        "training_config": {
            "loss_fn": "cross_entropy",
            "adam_params": {
                "learning_rate": 1e-05
            }
        }
    },
    "n_iterations": 5,
    "episodes_per_iter": 4
}